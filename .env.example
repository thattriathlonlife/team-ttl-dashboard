# TriTeam Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Backend only, never expose to frontend

# ── Meta WhatsApp Cloud API ────────────────────────────────────
WHATSAPP_TOKEN=your-meta-system-user-token
WHATSAPP_PHONE_ID=123456789012345             # Phone Number ID from Meta developer dashboard
WHATSAPP_CHANNEL_ID=your-channel-or-group-id # The WhatsApp channel/group to post into

# ── Frontend (Vite / Next.js — prefix with VITE_ or NEXT_PUBLIC_) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Optional: Mapbox (for the interactive race map) ────────────
VITE_MAPBOX_TOKEN=pk.eyJ...your-mapbox-public-token
